{
    "name": "likewinter/card-deck",
    "description": "Card deck games library",
    "type": "library",
    "require": {
        "php": "^8.4"
    },
    "require-dev": {
        "phpstan/phpstan": "^1.12",
        "pestphp/pest": "^4.2"
    },
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "Likewinter\\CardDeck\\": "src/"
        }
    },
    "authors": [
        {
            "name": "Anton Orlov",
            "email": "anton@pinked.ru"
        }
    ],
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "scripts": {
        "test": ["Composer\\Config::disableProcessTimeout", "pest"],
        "phpstan": "phpstan analyse",
        "ci": [
            "@phpstan",
            "@test"
        ]
    },
    "scripts-descriptions": {
        "test": "Run the Pest test suite",
        "phpstan": "Run PHPStan static analysis at level 8",
        "ci": "Run all CI checks (phpstan + tests)"
    }
}
